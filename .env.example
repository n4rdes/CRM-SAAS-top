# Copie este arquivo para .env.local e substitua pelos dados de
# Supabase > Project Settings > Data API / API Keys.
NEXT_PUBLIC_SUPABASE_URL=https://SEU-PROJETO.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_SUBSTITUA_AQUI

# Somente servidor. Nunca use NEXT_PUBLIC_ nestas variáveis.
SUPABASE_SECRET_KEY=sb_secret_SUBSTITUA_AQUI
NEXT_PUBLIC_APP_URL=http://localhost:3000

# HMAC para rate limiting. Gere um valor longo e aleatório em produção.
# Se ausente, o servidor usa SUPABASE_SECRET_KEY como fallback.
RATE_LIMIT_SECRET=SUBSTITUA_POR_UM_SEGREDO_ALEATORIO
# Ative somente quando a hospedagem controlar e limpar X-Forwarded-For.
TRUST_PROXY=false

# Stripe Billing (comece com as chaves do modo de teste).
STRIPE_SECRET_KEY=sk_test_SUBSTITUA_AQUI
STRIPE_WEBHOOK_SECRET=whsec_SUBSTITUA_AQUI
STRIPE_BASIC_PRICE_ID=price_SUBSTITUA_AQUI
STRIPE_PRO_PRICE_ID=price_SUBSTITUA_AQUI

# Documentos sensíveis. Recomendado: gateway ClamAV privado que aceite
# multipart/form-data no campo "file" e responda {"clean":true|false}.
DOCUMENT_SCANNER_URL=
DOCUMENT_SCANNER_TOKEN=
# Em produção, use true para bloquear uploads se o antivírus estiver indisponível.
DOCUMENT_REQUIRE_MALWARE_SCAN=false

# Testes opcionais de RLS em um projeto Supabase exclusivo de staging.
RUN_SUPABASE_INTEGRATION_TESTS=0
TEST_TENANT_A_EMAIL=
TEST_TENANT_A_PASSWORD=
TEST_TENANT_B_EMAIL=
TEST_TENANT_B_PASSWORD=

# Smoke test de um ambiente já publicado.
SMOKE_BASE_URL=http://localhost:3000
# Identificador opcional exibido no endpoint /api/health fora da Vercel.
APP_VERSION=local
